                      <Parameter AllowDbNull="false" AutogeneratedName="FechaFin" ColumnName="fecha_pedido" DataSourceName="DB_TRAMADE.dbo.COMPRAS" DataTypeServer="datetime" DbType="DateTime" Direction="Input" ParameterName="@FechaFin" Precision="0" ProviderType="DateTime" Scale="0" Size="8" SourceColumn="Fecha Pedido" SourceColumnNullMapping="false" SourceVersion="Current" />
                      <Parameter AllowDbNull="false" AutogeneratedName="IdSucursal" ColumnName="id_sucursal" DataSourceName="DB_TRAMADE.dbo.SUCURSAL" DataTypeServer="int" DbType="Int32" Direction="Input" ParameterName="@IdSucursal" Precision="0" ProviderType="Int" Scale="0" Size="4" SourceColumn="id_sucursal" SourceColumnNullMapping="false" SourceVersion="Current" />

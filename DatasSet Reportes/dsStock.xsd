INNER JOIN PRODUCTO p     ON ps.id_producto  = p.id_producto
INNER JOIN CATEGORIA cat  ON p.id_categoria  = cat.id_categoria
INNER JOIN SUCURSAL s     ON ps.id_sucursal  = s.id_sucursal
WHERE (@IdSucursal = 0 OR ps.id_sucursal = @IdSucursal)
ORDER BY s.nombre_sucursal, p.nombre_producto</CommandText>

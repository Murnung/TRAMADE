                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT 
    f.id_factura        AS 'NFactura',
    c.nombre_cliente    AS 'Cliente',
    u.nombre_usuario    AS 'Vendedor',
    s.nombre_sucursal   AS 'Sucursal',
    f.fecha_emision     AS 'Fecha',
    SUM(fp.cantidad * p.precio_unitario) AS 'Total'
FROM FACTURA f
INNER JOIN CLIENTE c          ON f.id_cliente   = c.id_cliente
INNER JOIN USUARIO u          ON f.id_usuario   = u.id_usuario
INNER JOIN SUCURSAL s         ON u.id_sucursal  = s.id_sucursal
INNER JOIN FACTURA_PRODUCTO fp ON f.id_factura  = fp.id_factura
INNER JOIN PRODUCTO p         ON fp.id_producto = p.id_producto
WHERE f.fecha_emision BETWEEN @FechaInicio AND @FechaFin
AND (@IdSucursal = 0 OR s.id_sucursal = @IdSucursal)
GROUP BY f.id_factura, c.nombre_cliente, u.nombre_usuario, 
         s.nombre_sucursal, f.fecha_emision
ORDER BY f.fecha_emision DESC</CommandText>
